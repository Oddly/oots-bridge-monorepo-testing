# =============================================================================
# OOTS Bridge E2E Testing - Environment Configuration
# =============================================================================
#
# Copy this file to .env and update values as needed:
#   cp .env.example .env
#
# The .env file is gitignored and should contain your local settings.
#
# =============================================================================

# -----------------------------------------------------------------------------
# Database Credentials
# -----------------------------------------------------------------------------
# IMPORTANT: Change these for production/staging environments!
MYSQL_ROOT_PASSWORD=root
MYSQL_BLUE_DATABASE=domibus_blue
MYSQL_RED_DATABASE=domibus_red

# -----------------------------------------------------------------------------
# Domibus Credentials
# -----------------------------------------------------------------------------
# IMPORTANT: Change these for production/staging environments!
DOMIBUS_ADMIN_USER=admin
DOMIBUS_ADMIN_PASSWORD=123456

# -----------------------------------------------------------------------------
# ActiveMQ Artemis Credentials
# -----------------------------------------------------------------------------
ARTEMIS_USER=admin
ARTEMIS_PASSWORD=admin

# -----------------------------------------------------------------------------
# Keystore Passwords
# -----------------------------------------------------------------------------
# IMPORTANT: Change these for production/staging environments!
KEYSTORE_PASSWORD=test123
TRUSTSTORE_PASSWORD=test123

# -----------------------------------------------------------------------------
# Service Ports (can be changed if ports conflict)
# -----------------------------------------------------------------------------
PORT_DOMIBUS_BLUE=8180
PORT_DOMIBUS_RED=8280
PORT_BRIDGE=3003
PORT_BRIDGE_HTTPS=3443
PORT_MOCK_EMREX=9081
PORT_ELASTICSEARCH=9200
PORT_KIBANA=5601

# -----------------------------------------------------------------------------
# Bridge Configuration
# -----------------------------------------------------------------------------
BRIDGE_LOG_LEVEL=debug
BRIDGE_SESSION_TIMEOUT_MS=300000

# -----------------------------------------------------------------------------
# Test Configuration
# -----------------------------------------------------------------------------
# Increase for slower systems or debugging
TEST_WAIT_TIME_MS=20000
TEST_ES_POLL_INTERVAL_MS=2000

# -----------------------------------------------------------------------------
# External URLs (for production-like testing)
# -----------------------------------------------------------------------------
# Set these to test against external services instead of docker network
# EXTERNAL_DOMIBUS_URL=
# EXTERNAL_EMREX_URL=
# EXTERNAL_BRIDGE_URL=
