# =============================================================================
# OOTS Bridge E2E Testing - Component Versions
# =============================================================================
#
# This file is the single source of truth for all component versions.
# Update versions here when upgrading components.
#
# To apply changes:
#   1. Update the version in this file
#   2. Run: task e2e:clean && task e2e:start
#   3. Run: task e2e:test to verify all paths still pass
#
# =============================================================================

# -----------------------------------------------------------------------------
# Domibus AS4 Gateway
# -----------------------------------------------------------------------------
# https://ec.europa.eu/digital-building-blocks/sites/display/DIGITAL/Domibus
# Image built locally from domibus/Dockerfile using the official EC eDelivery WAR
DOMIBUS_VERSION=5.1.9
DOMIBUS_SQL_DISTRIBUTION_VERSION=1.16
DOMIBUS_PLUGIN_DISTRIBUTION_VERSION=5.1.9

# -----------------------------------------------------------------------------
# Databases
# -----------------------------------------------------------------------------
MYSQL_VERSION=8.0.40

# -----------------------------------------------------------------------------
# Message Brokers
# -----------------------------------------------------------------------------
ACTIVEMQ_ARTEMIS_VERSION=2.31.2

# -----------------------------------------------------------------------------
# Logging Stack (ELK)
# -----------------------------------------------------------------------------
ELASTICSEARCH_VERSION=8.15.0
KIBANA_VERSION=8.15.0
FILEBEAT_VERSION=8.15.0

# -----------------------------------------------------------------------------
# Proxy & Web Servers
# -----------------------------------------------------------------------------
NGINX_VERSION=1.27.3-alpine

# -----------------------------------------------------------------------------
# Runtime Environments
# -----------------------------------------------------------------------------
NODE_VERSION=22.12.0-alpine3.21

# -----------------------------------------------------------------------------
# Application Versions (for tracking, not auto-applied)
# -----------------------------------------------------------------------------
# These are local builds - update when releasing new versions
OOTS_BRIDGE_VERSION=latest
OOTS_EMREX_VERSION=latest
